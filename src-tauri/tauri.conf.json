{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Combine Administrator Simulator",
  "version": "0.46.0",
  "identifier": "com.darknigthmare.combine-administrator-simulator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Combine Administrator Simulator",
        "width": 1440,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "category": "Game",
    "shortDescription": "Private COAN Combine administration desktop simulator",
    "longDescription": "Private fan-made COAN desktop terminal for managing a Combine occupied city simulation with Half-Life inspired administrative systems.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": [
          "fr-FR"
        ]
      }
    }
  }
}
