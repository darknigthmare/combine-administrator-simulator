{
  "name": "dazzling-pascal",
  "private": true,
  "version": "0.46.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "tauri build --target x86_64-pc-windows-msvc",
    "audit:coan": "node scripts/audit-upgrade-pack.mjs",
    "audit:balance": "node scripts/coan-balance-audit.mjs",
    "audit:onboarding": "node scripts/coan-onboarding-audit.mjs",
    "check:modules": "tsc -p tsconfig.modules.json --noEmit",
    "audit:newgame": "node scripts/coan-new-game-audit.mjs",
    "audit:session": "node scripts/coan-session-flow-audit.mjs",
    "audit:ux": "node scripts/coan-ux-polish-audit.mjs",
    "audit:tauri": "node scripts/coan-tauri-packaging-audit.mjs",
    "release:notes": "node scripts/coan-release-notes.mjs",
    "package:windows": "powershell -ExecutionPolicy Bypass -File scripts/coan-tauri-build-windows.ps1",
    "package:windows:offline": "powershell -ExecutionPolicy Bypass -File scripts/coan-tauri-build-windows.ps1 -OfflineWebView",
    "tauri:qa": "npm run check:modules && npm run audit:coan && npm run audit:tauri && npm run release:notes",
    "audit:all": "npm run audit:coan && npm run audit:balance && npm run audit:onboarding && npm run audit:newgame && npm run audit:session && npm run audit:ux && npm run audit:tauri"
  },
  "dependencies": {
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "^3.9.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  }
}
